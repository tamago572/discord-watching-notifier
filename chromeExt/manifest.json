{
  "manifest_version": 3,
  "name": "Discord Watching Notifier",
  "description": "視聴中の動画・アニメのタイトルをDiscordのアクティビティステータスに表示する拡張機能です。",
  "version": "1.0",
  "icons": {

  },
  "background": {
    "service_worker": "src/background/service-worker.ts",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://animestore.docomo.ne.jp/animestore/sc_d_pc?partId=*"
      ],
      "js": ["src/content/content.ts"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_icon": {

    },
    "default_popup": "index.html"
  },
  "permissions": ["nativeMessaging", "scripting", "activeTab", "tabs"]
}

